# Copy this file to .env and fill in real values. Never commit .env itself.

# Random long string used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-string

# Shared password committee members use to log in
COMMITTEE_PASSWORD=replace-with-a-real-password

# Optional: only needed if you switch off SQLite (e.g. to Postgres on a host)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
